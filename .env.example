# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bookmarkbrain
REDIS_URL=redis://localhost:6379

# Telegram
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_BOT_TOKEN=your_bot_token
MINI_APP_URL=https://your-mini-app.vercel.app

# AI
AI_PROVIDER=gigachat  # gigachat or claude
EMBEDDING_PROVIDER=gigachat  # gigachat or voyage
GIGACHAT_AUTH_KEY=your_gigachat_base64_key
ANTHROPIC_API_KEY=your_key
VOYAGE_API_KEY=your_voyage_key

# Speech-to-Text (Phase 3A/3D+)
# Provider: "yandex" (рекомендуется для RU), "openai", "groq"
STT_PROVIDER=yandex
WHISPER_API_KEY=                          # Только для openai/groq
YANDEX_CLOUD_API_KEY=AQVN...              # SpeechKit API key
YANDEX_CLOUD_FOLDER_ID=b1g...             # Yandex Cloud folder

# Yandex Object Storage — нужен для голосовых >30 секунд (async STT).
# Без этих переменных длинные голосовые отвергаются с понятной ошибкой.
# Setup checklist: memory/deployment.md (folder roles, static key, KMS off, allUsers:viewer).
YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net
YANDEX_S3_BUCKET=bookmarkbrain-stt
YANDEX_S3_ACCESS_KEY=YCAJE...
YANDEX_S3_SECRET_KEY=YCMv5...

# Mini App media uploads (3sr) — лимиты размера файла. Опционально (есть дефолты).
UPLOAD_MAX_AUDIO_MB=25
UPLOAD_MAX_DOC_MB=20

# App
SECRET_KEY=random_secret_for_jwt
BOT_SECRET=shared_secret_between_bot_and_backend
ENVIRONMENT=development

# Onboarding (Phase 2)
NUDGE_HOUR_UTC=6  # 9:00 MSK — час когда воркер шлёт stale-list nudge
