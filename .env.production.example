# ============================================================
# BookmarkBrain — Production Environment
# Copy to .env on your VPS and fill in real values
# ============================================================

# ── Database ──────────────────────────────────────────
POSTGRES_USER=bookmarkbrain
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=bookmarkbrain
# Composed automatically in docker-compose.prod.yml:
# DATABASE_URL=postgresql+asyncpg://...

# ── Redis ─────────────────────────────────────────────
# Composed automatically:
# REDIS_URL=redis://redis:6379

# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-YOUR-BOT-TOKEN
# Optional: Mini App URL (requires domain + SSL)
MINI_APP_URL=

# ── Security ──────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_KEY
BOT_SECRET=CHANGE_ME_GENERATE_RANDOM_KEY

# ── AI Providers ──────────────────────────────────────
AI_PROVIDER=gigachat
# GigaChat (classification)
GIGACHAT_AUTH_KEY=your_base64_key
GIGACHAT_CA_BUNDLE=

# Embeddings
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=your_voyage_key

# STT (voice messages)
# Options: "yandex" (works in Russia), "groq", "openai"
STT_PROVIDER=yandex
# Yandex SpeechKit (recommended for Russia/CIS)
YANDEX_CLOUD_API_KEY=your_yandex_api_key
YANDEX_CLOUD_FOLDER_ID=your_folder_id
# Groq/OpenAI (blocked from Russian IPs)
WHISPER_API_KEY=your_groq_api_key

# DeepSeek (alternative classifier)
DEEPSEEK_API_KEY=
# Anthropic (alternative classifier)
ANTHROPIC_API_KEY=

# ── App Settings ──────────────────────────────────────
ENVIRONMENT=production
# Stale list nudge hour (UTC). 6 = 9:00 MSK
NUDGE_HOUR_UTC=6

# ── Nginx (optional, for Mini App) ────────────────────
EXTERNAL_PORT=80
EXTERNAL_SSL_PORT=443
